@'
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
.coverage
htmlcov/

# Environment
.env
.env.local
.env.*.local

# Alembic runtime
backend/alembic/versions/__pycache__/

# Generated outputs
backend/reports/
backend/data/raw/*.parquet
backend/data/*.parquet

# Test batch files
backend/heavy_drift_batch*.json
backend/mild_drift_batch*.json
backend/normal_batch*.json
backend/normal_check*.json

# MLflow
mlruns/
mlartifacts/

# Node
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Coverage
.coverage
backend/.coverage
coverage.xml
'@ | Set-Content -Path .gitignore -Encoding utf8